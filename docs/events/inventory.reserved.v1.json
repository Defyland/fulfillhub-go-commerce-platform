{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Defyland/fulfillhub-go-commerce-platform/docs/events/inventory.reserved.v1.json",
  "title": "inventory.reserved v1",
  "type": "object",
  "required": [
    "message_id",
    "event_type",
    "schema_version",
    "occurred_at",
    "producer",
    "merchant_id",
    "order_id",
    "correlation_id",
    "causation_id",
    "payload"
  ],
  "properties": {
    "message_id": { "type": "string", "minLength": 1 },
    "event_type": { "type": "string", "const": "inventory.reserved" },
    "schema_version": { "type": "integer", "const": 1 },
    "occurred_at": { "type": "string", "format": "date-time" },
    "producer": { "type": "string", "minLength": 1 },
    "merchant_id": { "type": "string", "minLength": 1 },
    "order_id": { "type": "string", "minLength": 1 },
    "correlation_id": { "type": "string", "minLength": 1 },
    "causation_id": { "type": "string", "minLength": 1 },
    "payload": {
      "type": "object",
      "required": ["order_status", "reservations"],
      "properties": {
        "order_status": { "type": "string", "const": "inventory_reserved" },
        "reservations": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["sku", "quantity", "warehouse_id"],
            "properties": {
              "sku": { "type": "string", "minLength": 1 },
              "quantity": { "type": "integer", "minimum": 1 },
              "warehouse_id": { "type": "string", "minLength": 1 }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
